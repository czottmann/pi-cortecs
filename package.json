{
  "name": "@czottmann/pi-cortecs",
  "version": "2.0.1",
  "description": "Cortecs provider extension for pi coding agent. Install with `pi install npm:@czottmann/pi-cortecs`.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "url": "https://github.com/czottmann/pi-cortecs"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "cortecs",
    "llm",
    "router",
    "coding-agent"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/cortecs.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  }
}
