{
  "name": "pi-cortecs",
  "version": "1.1.0",
  "description": "Cortecs provider extension for pi coding agent. Install with `pi install npm:pi-cortecs`.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/czottmann/pi-cortecs.git"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "cortecs",
    "llm",
    "router",
    "coding-agent"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "check": "tsc --noEmit",
    "prepare": "npm run build"
  }
}
